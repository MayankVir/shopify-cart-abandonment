NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/dashboard
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/dashboard/onboarding

# Admin Access (comma-separated emails)
ADMIN_EMAILS=virmanimayank15@gmail.com

# Shopify OAuth (Automatic Connect flow)
SHOPIFY_API_KEY=
SHOPIFY_API_SECRET=
SHOPIFY_SCOPES=read_orders,read_customers,read_checkouts,write_checkouts,read_product_listings
SHOPIFY_APP_URL=http://localhost:3000
SHOPIFY_ALLOW_CART_WITHOUT_PHONE=

# Token encryption (32-byte hex key for AES-256)
ENCRYPTION_KEY=

# Tough Tongue AI — SIP dispatch + webhooks
TT_API_KEY=
TT_ORG_ID=
TT_BASE_URL=https://api.toughtongueai.com/api/public
# Signing secret shown when you create the TTAI webhook endpoint (Standard Webhooks)
TTAI_WEBHOOK_SECRET=

# uAgents context enrichment (shopify.gs)
UAGENTS_CUSTOMER_NAME=ttai
UAGENTS_TOKEN=
